//verificar si un valor es positivo o negtivo
Algoritmo numposneg
	Escribir "---numeros positivos y negativos----"
	Definir num Como Entero
	Escribir "Escribir un numero entero"
	leer num
	//Proceso 
	//salida
	si num>=0 Entonces
		Escribir " El numero es positivo"
	siNo 
		Escribir " El numero es negativo"
	FinSi
FinAlgoritmo
